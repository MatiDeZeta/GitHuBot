# Discord bot credentials (from https://discord.com/developers/applications)
# Optional at boot — without them the process still serves /health (degraded mode).
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: register slash commands to a single guild instantly during development
# DISCORD_GUILD_ID=

# 32-byte key for AES-256-GCM encryption of webhook secrets.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=

# Public base URL of this bot (no trailing slash). Used in /repo add setup instructions.
# Example: https://githubot.up.railway.app
PUBLIC_WEBHOOK_URL=http://localhost:3000

# SQLite file path (default) or Postgres connection string.
# SQLite:  file:./data/githubot.db
# Postgres: postgresql://user:pass@host:5432/githubot
DATABASE_URL=file:./data/githubot.db

# HTTP server
PORT=3000
HOST=0.0.0.0

# Logging: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
NODE_ENV=development

# NOTE: No GITHUB_TOKEN is required or accepted.
# GitHuBot never authenticates to the GitHub API.
