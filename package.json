{
  "name": "githubot",
  "version": "1.0.3",
  "description": "Beautiful Discord changelog messages for GitHub activity — zero GitHub credentials required",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@octokit/webhooks-methods": "^6.0.0",
    "better-sqlite3": "^13.0.1",
    "discord.js": "^14.27.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.18.13",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
